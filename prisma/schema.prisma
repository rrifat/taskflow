generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TicketHistoryType {
  CREATED
  UPDATED
  MOVED
  DELETED
}

model User {
  id           String     @id @default(uuid(7))
  email        String     @unique
  name         String?     
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  categories   Category[]
  tickets      Ticket[]
  history      TicketHistory[] @relation("TicketHistoryActor")
}

model Session {
  id         String   @id @default(uuid(7))
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String   @id @default(uuid(7))
  userId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets   Ticket[]

  @@index([userId])
  @@unique([userId, name])
}

model Ticket {
  id          String          @id @default(uuid(7))
  userId      String
  categoryId  String
  title       String
  description String
  expiryDate  DateTime
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  history     TicketHistory[]

  @@index([userId])
  @@index([categoryId, order])
}

model TicketHistory {
  id             String            @id @default(uuid(7))
  ticketId       String
  actorUserId    String
  type           TicketHistoryType
  fromCategoryId String?
  toCategoryId   String?
  changedFields  Json?
  createdAt      DateTime          @default(now())
  actor          User              @relation("TicketHistoryActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  ticket         Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([actorUserId])
}
